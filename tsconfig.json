{
	"compilerOptions": {
		"target": "ES2022",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"lib": ["ES2024", "DOM", "DOM.Iterable"],
		"strict": true,
		"skipLibCheck": true,
		"noUncheckedIndexedAccess": true,
		"verbatimModuleSyntax": true
	},
	"include": ["src/**/*.ts"],
	"exclude": ["src/**/*.test.ts"]
}
